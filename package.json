{
  "name": "tf-react-tech-test",
  "version": "1.0.0",
  "description": "Javascript Technical Test",
  "engines": {
    "node": "22.22.0"
  },
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.0"
  }
}
